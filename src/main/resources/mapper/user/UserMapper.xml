<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="maoomWeb.ire.user.mapper.UserMapper">

<!--
    사용자 기능의 DB 입출력 모음.
    로그인/계정/프로필/멘션 화면 -> UserController -> UserService 또는
    UserProfileImageService -> UserMapper.java -> 이 SQL 순서로 호출된다.
-->

<!-- tb_user의 로그인, 권한, Slack과 프로필 컬럼을 User DTO에 연결한다. -->
<resultMap id="UserResultMap" type="User">
    <id property="userId" column="user_id"/>
    <result property="userPw" column="user_pw"/>
    <result property="userName" column="user_name"/>
    <result property="userEmail" column="user_email"/>
    <result property="userRole" column="user_role"/>
    <result property="slackUserId" column="slack_user_id"/>
    <result property="profileImageStoredName" column="profile_image_stored_name"/>
    <result property="profileImageContentType" column="profile_image_content_type"/>
</resultMap>

<!-- 로그인 검증과 현재 사용자 정보 조회에 사용하는 사용자 한 건 조회. -->
<select id="getUserInfoById"
        resultMap="UserResultMap"
        parameterType="String">

    SELECT
        user_id,
        user_pw,
        user_name,
        user_email,
        user_role,
        slack_user_id,
        profile_image_stored_name,
        profile_image_content_type
    FROM tb_user
    WHERE user_id = #{userId}

</select>

<!-- PDF 댓글 입력창의 @멘션 자동완성 목록. 비밀번호와 Slack ID는 반환하지 않는다. -->
<select id="getMentionUsers"
        resultMap="UserResultMap">

    SELECT
        user_id,
        user_name,
        user_email,
        user_role
    FROM tb_user
    ORDER BY user_name, user_id

</select>

<!-- @사용자명 또는 @아이디를 실제 Slack 멤버 ID로 연결한다. 이름 일치를 우선한다. -->
<select id="getSlackUserIdByMention"
        parameterType="String"
        resultType="String">

    SELECT slack_user_id
    FROM tb_user
    WHERE user_name = #{mention}
       OR user_id = #{mention}
    ORDER BY
        CASE
            WHEN user_name = #{mention} THEN 0
            ELSE 1
        END
    LIMIT 1

</select>

<!-- 평문 마이그레이션과 계정 변경에서 생성한 BCrypt 해시를 저장한다. -->
<update id="updatePassword">

    UPDATE tb_user
    SET user_pw = #{userPw}
    WHERE user_id = #{userId}

</update>

<!-- 계정 설정에서 변경한 화면 표시 이름을 저장한다. -->
<update id="updateUserName">

    UPDATE tb_user
    SET user_name = #{userName}
    WHERE user_id = #{userId}

</update>

<!-- 실제 파일 저장 성공 후 프로필 이미지 파일명과 MIME 타입을 사용자와 연결한다. -->
<update id="updateProfileImage">

    UPDATE tb_user
    SET profile_image_stored_name = #{storedName},
        profile_image_content_type = #{contentType}
    WHERE user_id = #{userId}

</update>

<!-- 프로필 이미지 삭제 시 DB의 파일 연결 정보만 NULL로 초기화한다. -->
<update id="clearProfileImage">

    UPDATE tb_user
    SET profile_image_stored_name = NULL,
        profile_image_content_type = NULL
    WHERE user_id = #{userId}

</update>

</mapper>
