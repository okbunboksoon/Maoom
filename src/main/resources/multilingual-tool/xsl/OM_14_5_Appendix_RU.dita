<concept id="OM_14_5_Appendix_RU">
    <title>Табличка компрессора кондиционера</title>
    <titlealts/>
    <prolog>
        <metadata>
            <keywords>
                <indexterm> replacing components <indexterm>характеристики:табличка компрессора
                        кондиционера</indexterm>
                </indexterm>
            </keywords>
        </metadata>
    </prolog>
    <conbody>
        <table colsep="1" frame="none" outputclass="formatc_none" rowsep="1" id="table_j5h_xz2_2gc">
            <tgroup cols="2" colsep="0" rowsep="1">
                <colspec colname="col1" colnum="1" colsep="0" colwidth="50*"/>
                <colspec colname="col2" colnum="2" colsep="0" colwidth="50*"/>
